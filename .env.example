# Django 配置
# ========================================
# Django 密钥，生产环境必须修改为随机字符串
# 可以使用: python -c "import secrets; print(secrets.token_urlsafe(50))" 生成
SECRET_KEY=your-secret-key-change-in-production

# Django 调试模式，生产环境设置为 False
DEBUG=True

# 允许的主机，多个主机用逗号分隔
# 例如: localhost,example.com,www.example.com
ALLOWED_HOSTS=localhost

# PostgreSQL 数据库配置
# ========================================
# 数据库用户名
POSTGRES_USER=postgres

# 数据库密码，生产环境必须修改
POSTGRES_PASSWORD=postgres

# 数据库名称
POSTGRES_DB=postgres

# 数据库主机（docker 内部服务名）
POSTGRES_HOST=postgres

# 数据库端口
POSTGRES_PORT=5432

# RabbitMQ 消息队列配置
# ========================================
# RabbitMQ 用户名
RABBITMQ_USER=guest

# RabbitMQ 密码
RABBITMQ_PASSWORD=guest
